# ============================================================
# Copie este arquivo e preencha com os valores de produção.
# NÃO comite o arquivo com valores reais.
# ============================================================

# --- RAILWAY: API e Workers ---

# Supabase — pegue em: Project Settings > Database > Connection string
# DATABASE_URL  → Transaction pooler (porta 6543) — usado em runtime
# DIRECT_URL    → Direct connection (porta 5432)   — usado em migrations
DATABASE_URL="postgresql://postgres.xxxx:[PASSWORD]@aws-0-sa-east-1.pooler.supabase.com:6543/postgres"
DIRECT_URL="postgresql://postgres.[PROJECT]:[PASSWORD]@db.[PROJECT].supabase.co:5432/postgres"

# Upstash Redis — pegue em: upstash.com > seu database > Connect
REDIS_URL="rediss://user:password@host:port"

JWT_ACCESS_SECRET=""    # openssl rand -base64 64
JWT_REFRESH_SECRET=""   # openssl rand -base64 64
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

ENCRYPTION_KEY=""       # openssl rand -hex 32  (64 chars hex)

META_APP_ID="2156684861751630"
META_APP_SECRET=""
META_API_VERSION="v21.0"
META_REDIRECT_URI="https://SEU_DOMINIO_VERCEL.vercel.app/meta/callback"

NODE_ENV="production"
API_PORT=3001
WEB_URL="https://SEU_DOMINIO_VERCEL.vercel.app"
API_URL="https://SEU_DOMINIO_RAILWAY.railway.app"

RESEND_API_KEY=""       # opcional — para notificações de alerta por email
RESEND_FROM="alertas@seudominio.com"

# --- VERCEL: Web ---
# (adicione no painel da Vercel como variável de ambiente)

NEXT_PUBLIC_API_URL="https://SEU_DOMINIO_RAILWAY.railway.app"
