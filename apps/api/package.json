{
  "name": "@marketproads/api",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "dev": "nodemon",
    "build": "nest build",
    "start": "node dist/apps/api/src/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\"",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage"
  },
  "dependencies": {
    "@marketproads/crypto": "workspace:*",
    "@marketproads/database": "workspace:*",
    "@marketproads/types": "workspace:*",
    "dotenv": "^16.4.0",
    "@nestjs/common": "^10.4.0",
    "bullmq": "^5.13.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/jwt": "^10.2.0",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-fastify": "^10.4.0",
    "@nestjs/config": "^3.3.0",
    "argon2": "^0.41.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "reflect-metadata": "^0.2.0",
    "rxjs": "^7.8.0",
    "tsconfig-paths": "^4.2.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@marketproads/config": "workspace:*",
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.0",
    "@nestjs/testing": "^10.4.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^22.0.0",
    "@types/passport-jwt": "^4.0.1",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.0",
    "ts-jest": "^29.2.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.5.0"
  },
  "jest": {
    "moduleFileExtensions": ["js", "json", "ts"],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": { "^.+\\.ts$": "ts-jest" },
    "coverageDirectory": "../coverage",
    "testEnvironment": "node",
    "collectCoverageFrom": ["**/*.ts", "!**/*.spec.ts", "!**/index.ts", "!**/main.ts"],
    "moduleNameMapper": {
      "@marketproads/crypto": "<rootDir>/../../../packages/crypto/src/index.ts",
      "@marketproads/database": "<rootDir>/../../../packages/database/src/index.ts",
      "@marketproads/types": "<rootDir>/../../../packages/types/src/index.ts"
    }
  }
}
